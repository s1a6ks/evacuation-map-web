# ============================================================
# C# / .NET build artifacts
# ============================================================
**/bin/
**/obj/
**/.vs/
**/Debug/
**/Release/
**/*.dll
**/*.exe
**/*.pdb
**/*.cache

# ============================================================
# C# project/solution config (не наш код)
# ============================================================
**/*.sln
**/*.csproj
**/*.csproj.user
**/*.Designer.cs
**/AppDbContextModelSnapshot.cs
**/Migrations/

# ============================================================
# Database files
# ============================================================
**/*.db
**/*.db-shm
**/*.db-wal

# ============================================================
# App config / environment (не код проекту)
# ============================================================
**/appsettings.json
**/appsettings.Development.json
**/*.http
**/launchSettings.json

# ============================================================
# React / Node artifacts
# ============================================================
**/node_modules/
**/dist/
**/.env
**/coverage/

# ============================================================
# Frontend tooling configs (boilerplate)
# ============================================================
**/vite.config.js
**/tailwind.config.js
**/postcss.config.js
**/eslint.config.js
**/package.json
**/index.html

# ============================================================
# Frontend non-code assets
# ============================================================
**/public/
**/assets/
**/*.svg
**/*.css

# ============================================================
# Lock files & tooling configs
# ============================================================
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml

# ============================================================
# Git / IDE / misc
# ============================================================
**/.gitignore
**/.claudeignore
**/README.md
**/install.cmd
**/*.log
**/*.tmp
**/*.md
